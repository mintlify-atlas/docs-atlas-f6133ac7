  "keyFeatures": [
    "JWT-based authentication with email and phone verification",
    "Multi-step user onboarding with profile completion tracking",
    "Loan application management with status tracking",
    "Cashir transaction processing with multiple payment channels",
    "Integrated wallet system using bavix/laravel-wallet",
    "Document upload and verification for KYC",
    "Guarantor, employment, residential, and banking information management",
    "SMS verification via Twilio integration",
    "Transaction PIN security for sensitive operations"
  ],
